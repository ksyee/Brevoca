{
  "name": "@brevoca/workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Brevoca workspace",
  "packageManager": "pnpm@10.28.0",
  "pnpm": {
    "onlyBuiltDependencies": ["ffmpeg-static"]
  },
  "scripts": {
